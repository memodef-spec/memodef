  "id": "memodef-canonical-template-library",
  "name": "memodef Canonical Template Library",
  "description": "The canonical library of memo templates, curated by the memodef community. Each entry is a memodef:Memo artifact demonstrating a canonical pattern adopters can copy from. memodef does NOT curate operational memos — operational memos live in adopter orgs' per-position working repos per the org's declared memo-location convention.",
  "version": "0.1.0",

